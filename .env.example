# ── Required ──────────────────────────────────────────────────────────────────
# OpenAI API key — used for conversation generation and LLM-as-judge scoring.
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────────────────
# Anthropic API key — alternative model backend (Claude).
# ANTHROPIC_API_KEY=sk-ant-...

# ── Model config (override defaults in config/default.yaml) ──────────────────
# GENERATOR_MODEL=gpt-4o-mini
# JUDGE_MODEL=gpt-4o
